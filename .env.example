RERANK_TOP_N=5

# Evaluation Thresholds
EVAL_FAITHFULNESS_THRESHOLD=0.8
EVAL_RELEVANCY_THRESHOLD=0.7
EVAL_PRECISION_THRESHOLD=0.7
